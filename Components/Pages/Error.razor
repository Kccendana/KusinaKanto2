@page "/Error"
@rendermode InteractiveServer

<PageTitle>Error</PageTitle>

<div class="min-h-screen bg-stone-50 flex items-center justify-center px-4">
    <div class="text-center">
        <h1 class="text-2xl font-bold text-stone-900 mb-2">Something went wrong</h1>
        <p class="text-stone-500 mb-6">An unexpected error occurred while processing your request.</p>
        <a href="/" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl font-medium transition-colors">
            Back to menu
        </a>
    </div>
</div>
