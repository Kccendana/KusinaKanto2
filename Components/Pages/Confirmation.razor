@page "/confirmation"
@inject CartState Cart
@inject NavigationManager Nav

@if (_order is not null)
{
    <div class="min-h-screen bg-stone-50 flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
                <!-- Top banner -->
                <div class="bg-gradient-to-br from-amber-500 to-amber-600 px-6 py-8 text-center text-white">
                    <div class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
                        <Icon Name="circle-check-big" Class="w-10 h-10 text-white" />
                    </div>
                    <h1 class="text-2xl font-bold mb-1">Order Placed!</h1>
                    @if (_order.TableNumber.HasValue)
{
    <p class="text-amber-100 text-sm">
        Table @_order.TableNumber Order Received
    </p>
}
else
{
    <p class="text-amber-100 text-sm">
        Take-Out Order Received
    </p>
}
                    <div class="mt-3 bg-white/20 rounded-xl px-4 py-2 inline-block">
                        <p class="text-xs text-amber-100">Order ID</p>
                        <p class="font-mono font-bold text-sm">#@OrderCode</p>
                    </div>
                </div>

                <div class="px-6 py-5 space-y-5">
                    <!-- Status tracker -->
                    <div>
                        <div class="flex items-center gap-1 text-stone-500 text-sm mb-3">
                            <Icon Name="clock" Class="w-4 h-4" />
                            <span>Order Status</span>
                        </div>
                        <div class="flex items-center">
                            @for (var idx = 0; idx < Steps.Length; idx++)
                            {
                                var stepIndex = idx;
                                <div class="flex items-center flex-1">
                                    <div class="flex flex-col items-center flex-shrink-0">
                                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold transition-colors @(stepIndex <= CurrentStep ? "bg-amber-500 text-white" : "bg-stone-100 text-stone-400")">
                                            @(stepIndex < CurrentStep ? "✓" : (stepIndex + 1).ToString())
                                        </div>
                                        <span class="text-xs mt-1 text-center leading-tight w-14 @(stepIndex <= CurrentStep ? "text-amber-600 font-medium" : "text-stone-400")">
                                            @Steps[stepIndex]
                                        </span>
                                    </div>
                                    @if (stepIndex < Steps.Length - 1)
                                    {
                                        <div class="flex-1 h-0.5 mx-1 mb-4 @(stepIndex < CurrentStep ? "bg-amber-400" : "bg-stone-200")"></div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Order details -->
                    <div class="bg-stone-50 rounded-2xl p-4">
                        <p class="text-xs font-semibold text-stone-400 uppercase tracking-wide mb-3">Order Details</p>
                        <div class="space-y-2">
                            @foreach (var line in _items)
                            {
                                <div class="flex items-center justify-between text-sm">
                                    <span class="text-stone-700">@line.Item.Name <span class="text-stone-400">×@line.Quantity</span></span>
                                    <span class="font-medium text-stone-900">¥@line.Subtotal</span>
                                </div>
                            }
                        </div>
                        <div class="flex items-center justify-between mt-3 pt-3 border-t border-stone-200 font-bold text-stone-900">
                            <span>Total Paid</span>
                            <span>¥@_order.TotalAmount</span>
                        </div>
                        <div class="flex items-center justify-between mt-2 text-sm text-stone-500">
    <span>Order Type</span>

    @if (_order.TableNumber.HasValue)
    {
        <span>Table @_order.TableNumber</span>
    }
    else
    {
        <span>Take-Out</span>
    }
</div>
                    </div>

                    <button @onclick="OrderMore"
                            class="w-full flex items-center justify-center gap-2 bg-stone-900 hover:bg-stone-700 text-white py-3.5 rounded-xl font-semibold text-sm transition-all duration-200 shadow-md hover:shadow-lg">
                        Order More Food
                        <Icon Name="chevron-right" Class="w-4 h-4" />
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] Steps = { "Order Received", "Confirmed", "Preparing", "Ready" };

    private Order? _order;
    private List<CartLine> _items = new();

    private string OrderCode => _order?.Id.ToString("D4") ?? "";
    private int CurrentStep => _order is null ? 0 : (int)_order.Status;

    protected override void OnInitialized()
    {
        _order = Cart.LastOrder;
        _items = Cart.LastItems;
        if (_order is null)
            Nav.NavigateTo("/");
    }

    private void OrderMore()
    {
    var tableNumber = _order?.TableNumber;

    Cart.LastOrder = null;
    Cart.LastItems.Clear();

    Nav.NavigateTo(tableNumber.HasValue
        ? $"/{tableNumber.Value}"
        : "/");
    }
}
